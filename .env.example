# -----------------------------------------------------------------------------
# Configuration variables for Roblox Status Watcher
# Rename this file to '.env' and fill in your details.
# -----------------------------------------------------------------------------

# Roblox Usernames to watch (comma-separated, e.g., UsernameA,UsernameB)
ROBLOX_USERNAMES=Roblox,Builderman

# Discord Webhook URL for status updates notifications
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# (Optional) Vercel Cron authorization secret. 
# Used to secure endpoint when deployed. If not provided, secret check is bypassed.
# CRON_SECRET=your_vercel_cron_secret

# (Optional) Vercel KV (Redis) Credentials.
# If omitted or left empty, the application will automatically fall back 
# to a local file store (.local-kv.json) for easy local development.
KV_REST_API_URL=
KV_REST_API_TOKEN=
