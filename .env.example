# -----------------------------------------------------------------------------
#  Roblox Status Watcher — Environment Variables
#
#  LOCAL DEVELOPMENT:
#    Rename/copy this file to '.env' dan isi nilainya.
#    File '.env' akan otomatis dibaca oleh local-server.js.
#
#  PRODUCTION (Vercel):
#    Jangan commit file '.env'. Atur semua variabel langsung dari
#    Vercel Dashboard → Project → Settings → Environment Variables.
#    Sistem akan otomatis membaca nilai dari sana.
# -----------------------------------------------------------------------------


# ── WAJIB ────────────────────────────────────────────────────────────────────

# Username Roblox yang ingin dipantau.
# Gunakan koma untuk beberapa user. Contoh: UsernameA,UsernameB,UsernameC
# Catatan: User yang sudah ditambahkan via dashboard Settings akan MENGABAIKAN nilai ini.
ROBLOX_USERNAMES=Builderman

# Discord Webhook URL untuk notifikasi perubahan status.
# Cara mendapatkannya: Channel Discord → Edit → Integrations → Webhooks → New Webhook → Copy URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/XXXXXXXX/XXXXXXXXXXXXXXXX


# ── OPSIONAL ─────────────────────────────────────────────────────────────────

# Secret untuk mengamankan endpoint Vercel Cron (/api/check-roblox).
# Jika diisi, Vercel akan mengirimkan header Authorization: Bearer <secret> di setiap request cron.
# CRON_SECRET=

# Vercel KV (Redis) — untuk state persistence di production.
# Jika dikosongkan, sistem otomatis pakai file lokal '.local-kv.json' sebagai fallback.
# Di Vercel: variabel ini otomatis ditambahkan setelah kamu connect Storage → KV di dashboard.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
