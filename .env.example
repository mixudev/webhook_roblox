# -----------------------------------------------------------------------------
#  Roblox Status Watcher — Environment Variables
#
#  LOCAL DEVELOPMENT:
#    Rename/copy file ini ke '.env' dan isi nilainya.
#    File '.env' akan otomatis dibaca oleh local-server.js.
#    Upstash tidak diperlukan untuk lokal — sistem pakai .local-kv.json otomatis.
#
#  PRODUCTION (Vercel):
#    Jangan commit file '.env'. Atur semua variabel langsung dari
#    Vercel Dashboard → Project → Settings → Environment Variables.
# -----------------------------------------------------------------------------


# ── WAJIB ────────────────────────────────────────────────────────────────────

# Username Roblox yang ingin dipantau (pisahkan koma untuk multiple).
# Catatan: User yang ditambah via dashboard Settings akan mengabaikan nilai ini.
ROBLOX_USERNAMES=Builderman

# Discord Webhook URL untuk notifikasi perubahan status.
# Cara: Channel Discord → Edit → Integrations → Webhooks → New Webhook → Copy URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/XXXXXXXX/XXXXXXXXXXXXXXXX

# Secret untuk mengamankan endpoint /api/check-roblox dari akses luar.
# Gunakan nilai yang SAMA persis di Vercel dan GitHub Secrets.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=


# ── OPSIONAL (Upstash Redis — persistence di production) ──────────────────────
#
# Tanpa ini, sistem tetap berjalan tapi state tidak tersimpan antar request.
# Untuk lokal: biarkan kosong, sistem pakai .local-kv.json otomatis.
# Untuk production: connect Upstash dari Vercel Marketplace, env ini diisi otomatis.
#
# KV_REST_API_URL=     ← (jika masih pakai @vercel/kv lama)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
